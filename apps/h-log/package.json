{
  "name": "h-log",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --no-warnings --test --experimental-strip-types lib/**/*.test.ts",
    "test:migrations": "node --test scripts/blog-migrations.integration.test.mjs",
    "test:repository": "node --no-warnings --test --experimental-strip-types lib/blog-postgres-repository.integration.test.ts",
    "test:public-read-path": "node --no-warnings --test --experimental-strip-types lib/blog-public-read-path.integration.test.ts",
    "test:worker": "node --no-warnings --test --experimental-strip-types lib/blog-persistent-worker.integration.test.ts",
    "test:dry-run": "node --no-warnings --test --experimental-strip-types lib/blog-local-dry-run.integration.test.ts",
    "db:migrate": "node scripts/blog-migrations.mjs",
    "auto-publish:once": "node --no-warnings --experimental-strip-types scripts/blog-auto-publish.mjs --once",
    "dry-run:local": "node --no-warnings --experimental-strip-types scripts/blog-local-dry-run.mjs",
    "worker:once": "node --no-warnings --experimental-strip-types scripts/blog-worker.mjs --once",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
